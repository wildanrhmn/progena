{
  "name": "progena-contracts",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "deploy:galileo": "hardhat ignition deploy ignition/modules/Progena.ts --network galileo",
    "deploy:mainnet": "hardhat ignition deploy ignition/modules/Progena.ts --network mainnet",
    "deploy:registry:mainnet": "hardhat run scripts/deploy-agent-registry.ts --network mainnet",
    "claim:founders:mainnet": "hardhat run scripts/claim-founder-names.ts --network mainnet",
    "breed:demo:mainnet": "hardhat run scripts/breed-demo.ts --network mainnet",
    "deploy:metadata:mainnet": "hardhat run scripts/deploy-metadata.ts --network mainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^4.0.0",
    "@types/node": "^22.10.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.26.0",
    "typescript": "^5.6.3",
    "viem": "^2.21.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.6.1"
  }
}
